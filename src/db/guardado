export const db = drizzle(
  async (sql, params, method) => {
    const sqlite = await getDb();
    try {
      const queryNormalizada = sql.trim().toUpperCase();
      if (
        queryNormalizada === "BEGIN" ||
        queryNormalizada === "COMMIT" ||
        queryNormalizada === "ROLLBACK"
      ) {
        return { rows: [] };
      }

      if (method === "run") {
        const result = await sqlite.execute(sql, params);

        const queryNormalizada = sql.trim().toUpperCase();
        const esMutacion = /^(INSERT|UPDATE|DELETE|REPLACE)/.test(
          queryNormalizada,
        );

        // IMPORTANTE: No capturamos cambios que ocurren en la propia tabla de sincronización
        const esTablaSync =
          queryNormalizada.includes("PENDINGSYNC") ||
          queryNormalizada.includes("SYNCSTATE");

        if (esMutacion && !esTablaSync && !isSyncingFromServer) {
          // 1. Extracción robusta del nombre de la tabla
          const match = queryNormalizada.match(
            /(?:INSERT INTO|UPDATE|DELETE FROM|REPLACE INTO)\s+["`]?(\w+)["`]?/i,
          );
          const tableName = match ? match[1] : "unknown";

          // 2. Crear el payload de Yjs
          const updatePayload = createUpdate(tableName, {
            params,
            timestamp: Date.now(),
          });

          // 3. Convertir Uint8Array a Array normal (Tauri lo prefiere así para BLOBs)
          const uint8Array = new Uint8Array(updatePayload);
          const payloadAsArray = Array.from(uint8Array);

          try {
            await sqlite.execute(
              "INSERT INTO PendingSync (id, tabla, metodo, update_payload) VALUES (?, ?, ?, ?)",
              [uuidv4(), tableName, method, payloadAsArray],
            );

            // Llamamos a la sincronización
            syncWithBackend();
          } catch (err) {
            console.error("Error guardando en PendingSync:", err);
          }
        }
        return { rows: [] };
      }

      const rows = await sqlite.select<any[]>(sql, params);

      if (method === "get") {
        // Engañamos a TypeScript usando 'as any' para el undefined,
        // pero mantenemos el comportamiento que arregló tu bug.
        return {
          rows: rows[0] ? Object.values(rows[0]) : (undefined as any),
        };
      }

      return { rows: rows.map((row) => Object.values(row)) };
    } catch (e) {
      console.error("Error en el puente de Rust:", e);
      console.error("Query que falló:", sql);

      throw e;
    }
  },
  { schema: { ...schema, ...relations } },
);
